# Radar — örnek .env (gerçek değerleri DOLDURUP .env olarak kaydedin)
# .env asla git'e commit edilmez (.gitignore içinde)

# ── Flask ────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
APP_PREFIX=                       # nginx prefix (örn: /radar) — boş = root
APP_VERSION=1.0.0
DOMAIN_NAME=localhost:8005

# ── Database ─────────────────────────────────────────────
# Boş bırakılırsa SQLite (data/radar.db) kullanılır
DATABASE_URL=                     # postgresql://user:pass@host:5432/radar

# ── Rate limiter storage ─────────────────────────────────
# memory:// = tek-worker (geliştirme); prod'da Redis önerilir (workers arası
# paylaşımlı sayaç). Yoksa flask-limiter etkisiz kalır.
LIMITER_STORAGE_URI=memory://     # prod: redis://localhost:6379/1

# ── Mail (verify, reset) ─────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-app@gmail.com
MAIL_PASSWORD=app-password-here   # Gmail App Password önerilir
ADMIN_EMAIL=admin@example.com

# ── Google OAuth (opsiyonel) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CONF_URL=https://accounts.google.com/.well-known/openid-configuration

# ── Deployment (sadece prod ssh için, repoya commit edilmez) ──
SERVER_IP=
SERVER_USER=
SERVER_PASS=
